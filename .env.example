# BMA Website Environment Variables
# Copy this file to apps/bma-web/.env.local and fill in values

# ─── Site ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bluemodernadviosry.com

# ─── Integrations ───────────────────────────────────────────────────────────
# Clay - visitor tracking and contact form CRM push
# Get from: https://app.clay.com/settings/api
CLAY_API_KEY=

# Slack - form submission notifications to #website-visitors
# Get from: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=

# ─── Analytics ──────────────────────────────────────────────────────────────
# Add your analytics provider key here
NEXT_PUBLIC_ANALYTICS_ID=
